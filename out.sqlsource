CREATE TABLE IF NOT EXISTS "where_is_this_wherequestion" ("id" integer NOT NULL PRIMARY KEY AUTOINCREMENT, "question_text" text NOT NULL, "image" varchar(100) NULL, "correct_latitude" real NOT NULL, "correct_longitude" real NOT NULL, "points" integer unsigned NOT NULL CHECK ("points" >= 0), "difficulty" varchar(10) NOT NULL, "time_limit" integer unsigned NOT NULL CHECK ("time_limit" >= 0), "perfect_distance" real NOT NULL, "good_distance" real NOT NULL, "fair_distance" real NOT NULL, "poor_distance" real NOT NULL, "explanation" text NULL, "created_at" datetime NOT NULL, "is_active" bool NOT NULL, "created_by_id" integer NOT NULL REFERENCES "auth_user" ("id") DEFERRABLE INITIALLY DEFERRED, "hint_text" text NULL);
INSERT INTO where_is_this_wherequestion VALUES(1,'Where is Mount Everest?','',59.00436499999999996,91.82646099999999478,100,'medium',60,10.0,100.0,500.0,2000.0,NULL,'2025-09-09 01:00:15.386354',1,1,NULL);

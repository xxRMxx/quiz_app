CREATE TABLE IF NOT EXISTS "auth_group_permissions" ("id" integer NOT NULL PRIMARY KEY AUTOINCREMENT, "group_id" integer NOT NULL REFERENCES "auth_group" ("id") DEFERRABLE INITIALLY DEFERRED, "permission_id" integer NOT NULL REFERENCES "auth_permission" ("id") DEFERRABLE INITIALLY DEFERRED);
CREATE TABLE IF NOT EXISTS "auth_user_groups" ("id" integer NOT NULL PRIMARY KEY AUTOINCREMENT, "user_id" integer NOT NULL REFERENCES "auth_user" ("id") DEFERRABLE INITIALLY DEFERRED, "group_id" integer NOT NULL REFERENCES "auth_group" ("id") DEFERRABLE INITIALLY DEFERRED);
CREATE TABLE IF NOT EXISTS "auth_user_user_permissions" ("id" integer NOT NULL PRIMARY KEY AUTOINCREMENT, "user_id" integer NOT NULL REFERENCES "auth_user" ("id") DEFERRABLE INITIALLY DEFERRED, "permission_id" integer NOT NULL REFERENCES "auth_permission" ("id") DEFERRABLE INITIALLY DEFERRED);
CREATE TABLE IF NOT EXISTS "Assign_assignquestion" ("id" integer NOT NULL PRIMARY KEY AUTOINCREMENT, "question_text" text NOT NULL, "points" integer unsigned NOT NULL CHECK ("points" >= 0), "time_limit" integer unsigned NOT NULL CHECK ("time_limit" >= 0), "left_items" text NOT NULL CHECK ((JSON_VALID("left_items") OR "left_items" IS NULL)), "right_items" text NOT NULL CHECK ((JSON_VALID("right_items") OR "right_items" IS NULL)), "correct_matches" text NOT NULL CHECK ((JSON_VALID("correct_matches") OR "correct_matches" IS NULL)), "explanation" text NOT NULL, "created_at" datetime NOT NULL, "created_by_id" integer NOT NULL REFERENCES "auth_user" ("id") DEFERRABLE INITIALLY DEFERRED);
INSERT INTO Assign_assignquestion VALUES(1,'Match Countries with their capitals',10,60,'["Kenya", "Uganda"]','["Nairobi", "Kampala"]','{"0": 0, "1": 1}','','2025-11-10 19:28:01.321710',2);
CREATE TABLE IF NOT EXISTS "Estimation_estimationquestion" ("id" integer NOT NULL PRIMARY KEY AUTOINCREMENT, "question_text" text NOT NULL, "correct_answer" real NOT NULL, "unit" varchar(20) NOT NULL, "difficulty" varchar(10) NOT NULL, "max_points" integer unsigned NOT NULL CHECK ("max_points" >= 0), "tolerance_percentage" real NOT NULL, "hint_text" text NULL, "explanation" text NULL, "is_active" bool NOT NULL, "created_at" datetime NOT NULL, "created_by_id" integer NOT NULL REFERENCES "auth_user" ("id") DEFERRABLE INITIALLY DEFERRED);
INSERT INTO Estimation_estimationquestion VALUES(1,'How tall is mount Everest?',8848.0,'number','easy',100,10.0,NULL,NULL,1,'2025-08-30 11:14:06.202194',1);
INSERT INTO Estimation_estimationquestion VALUES(2,'How far is Germany from France?',2000.0,'kilometers','medium',100,10.0,NULL,NULL,1,'2025-08-30 11:33:28.055554',1);
INSERT INTO Estimation_estimationquestion VALUES(3,'How fast is the fastest car?',496.2200000000000272,'kmh','medium',100,10.0,NULL,NULL,1,'2025-11-10 12:13:41.419843',2);
CREATE TABLE IF NOT EXISTS "QuizGame_quizquestion" ("id" integer NOT NULL PRIMARY KEY AUTOINCREMENT, "question_text" text NOT NULL, "question_type" varchar(20) NOT NULL, "points" integer unsigned NOT NULL CHECK ("points" >= 0), "time_limit" integer unsigned NOT NULL CHECK ("time_limit" >= 0), "option_a" varchar(200) NOT NULL, "option_b" varchar(200) NOT NULL, "option_c" varchar(200) NOT NULL, "option_d" varchar(200) NOT NULL, "correct_answer" varchar(500) NOT NULL, "explanation" text NOT NULL, "created_at" datetime NOT NULL, "created_by_id" integer NOT NULL REFERENCES "auth_user" ("id") DEFERRABLE INITIALLY DEFERRED);
INSERT INTO QuizGame_quizquestion VALUES(1,'What is the red planet','multiple_choice',10,30,'Venus','Mars','Jupiter','Saturn','B','','2025-11-10 11:55:54.149823',2);
INSERT INTO QuizGame_quizquestion VALUES(2,'What is the chemical symbol for gold?','multiple_choice',10,30,'Ag','Au','Gd','Go','B','','2025-11-10 11:56:56.797031',2);
CREATE TABLE IF NOT EXISTS "django_admin_log" ("id" integer NOT NULL PRIMARY KEY AUTOINCREMENT, "object_id" text NULL, "object_repr" varchar(200) NOT NULL, "action_flag" smallint unsigned NOT NULL CHECK ("action_flag" >= 0), "change_message" text NOT NULL, "content_type_id" integer NULL REFERENCES "django_content_type" ("id") DEFERRABLE INITIALLY DEFERRED, "user_id" integer NOT NULL REFERENCES "auth_user" ("id") DEFERRABLE INITIALLY DEFERRED, "action_time" datetime NOT NULL);
CREATE TABLE IF NOT EXISTS "django_content_type" ("id" integer NOT NULL PRIMARY KEY AUTOINCREMENT, "app_label" varchar(100) NOT NULL, "model" varchar(100) NOT NULL);

CREATE TABLE IF NOT EXISTS "who_is_lying_whoquestion" ("id" integer NOT NULL PRIMARY KEY AUTOINCREMENT, "statement" text NOT NULL, "points" integer unsigned NOT NULL CHECK ("points" >= 0), "time_limit" integer unsigned NOT NULL CHECK ("time_limit" >= 0), "people" text NOT NULL CHECK ((JSON_VALID("people") OR "people" IS NULL)), "explanation" text NOT NULL, "created_at" datetime NOT NULL, "created_by_id" integer NOT NULL REFERENCES "auth_user" ("id") DEFERRABLE INITIALLY DEFERRED);
INSERT INTO who_is_lying_whoquestion VALUES(1,'I have won an Oscar.',10,60,'[{"name": "Cristiano", "is_lying": true}, {"name": "Nolan", "is_lying": true}, {"name": "Michael C.Hall", "is_lying": false}]','','2025-09-01 10:35:03.421689',1);

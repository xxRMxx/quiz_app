CREATE TABLE IF NOT EXISTS "who_is_that_whothatquestion" ("id" integer NOT NULL PRIMARY KEY AUTOINCREMENT, "question_text" varchar(200) NOT NULL, "image" varchar(100) NOT NULL, "correct_answer" varchar(200) NOT NULL, "alternative_answers" text NOT NULL CHECK ((JSON_VALID("alternative_answers") OR "alternative_answers" IS NULL)), "difficulty" varchar(10) NOT NULL, "points" integer unsigned NOT NULL CHECK ("points" >= 0), "time_limit" integer unsigned NOT NULL CHECK ("time_limit" >= 0), "hint_text" text NULL, "explanation" text NULL, "category" varchar(100) NULL, "is_active" bool NOT NULL, "created_at" datetime NOT NULL, "created_by_id" integer NOT NULL REFERENCES "auth_user" ("id") DEFERRABLE INITIALLY DEFERRED);
INSERT INTO who_is_that_whothatquestion VALUES(1,'Who is this person?','who_that_images/FB_IMG_1638810799652.jpg','Muhammad Ayaz','["Ayaz"]','medium',100,30,NULL,NULL,NULL,1,'2025-09-01 20:15:33.489633',1);
CREATE TABLE IF NOT EXISTS "black_jack_quiz_blackjackquestion" ("id" integer NOT NULL PRIMARY KEY AUTOINCREMENT, "question_text" text NOT NULL, "correct_answer" integer NOT NULL, "difficulty" varchar(10) NOT NULL, "time_limit" integer unsigned NOT NULL CHECK ("time_limit" >= 0), "hint_text" text NULL, "explanation" text NULL, "is_active" bool NOT NULL, "created_at" datetime NOT NULL, "created_by_id" integer NOT NULL REFERENCES "auth_user" ("id") DEFERRABLE INITIALLY DEFERRED);
